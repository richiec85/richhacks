---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import avatar from "../assets/richard.jpg";
---

<Base
  title="About"
  description="Richard Carragher — 30+ years in IT and cybersecurity, writing up homelab, security and AI practice from the rack."
>
  <section class="about">
    <Image src={avatar} alt="Richard Carragher" width={120} height={120} class="avatar-large" />
    <h1>About</h1>
    <p>
      I'm Richard — 30+ years in IT and cybersecurity, currently running a homelab that
      occasionally fights back. RichHacks is where the war-stories, the security practice, and
      the AI tooling experiments get written up properly.
    </p>
  </section>
</Base>

<style>
  .about {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  .avatar-large {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--hairline);
  }
  .about h1 {
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 1.4rem + 1.5vw, 2.5rem);
    color: var(--text);
  }
  .about p {
    margin-top: 1rem;
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text);
  }
</style>
